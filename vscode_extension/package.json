{
    "name": "promqueen-extension",
    "displayName": "PromQueen Pipeline",
    "description": "Run PromQueen pipeline in VS Code",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "promqueen.runPipeline",
                "title": "PromQueen: Run Pipeline"
            },
            {
                "command": "promqueen.previewPrompt",
                "title": "PromQueen: Preview Prompt"
            },
            {
                "command": "promqueen.regenerateLastMessage",
                "title": "PromQueen: Regenerate Last Message"
            }
        ],
        "languages": [
            {
                "id": "promqueen-pqueen",
                "aliases": [
                    "PromQueen Prompt",
                    "pqueen"
                ],
                "extensions": [
                    ".pqueen"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "promqueen-pqueen",
                "scopeName": "source.pqueen",
                "path": "./syntaxes/pqueen.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run build",
        "watch": "npm run watch:esbuild",
        "watch:esbuild": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
        "package": "npm run build -- --minify",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src --ext ts",
        "test": "node ./dist/extension.js || node ./test/run_test.js",
        "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.1",
        "@types/node": "16.x",
        "@types/vscode": "^1.75.0",
        "esbuild": "^0.24.2",
        "eventsource-parser": "^3.0.6",
        "js-yaml": "^4.1.1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/placeholder/promqueen-extension.git"
    },
    "dependencies": {}
}